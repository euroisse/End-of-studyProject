// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Base User model
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Employee related fields
  poste          String?
  department     String?
  profilePicture String?
  projects       EmployeeOnProjects[]
  tasks          Tasks[]              @relation("AssignedTasks")
  // Client related fields
  adresse        String?
  company        String?
  industry       String?
  contacts       String?
  clientProjects Project[]            @relation("CustomerProjects")
  clientQuote    Quote[]
  clientInvoice  Invoice[]
  notification   Notification[]       @relation("UserNotifications")

  // Role management
  UserRole UserRole[]
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userRoles UserRole[]
}

model UserRole {
  userId     Int
  roleId     Int
  assignedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  // Composite primary key
  @@id([userId, roleId])
}

model Project {
  id            Int                  @id @default(autoincrement())
  customer      User                 @relation("CustomerProjects", fields: [customerId], references: [id])
  customerId    Int
  title         String
  description   String?
  users         EmployeeOnProjects[]
  projectQuote  Quote[]
  notification  Notification[]       @relation("ProjectNotifications")
  projectStages ProjectStage[]
  tasks         Tasks[]              @relation("ProjectTasks")
  startDate     DateTime             @default(now()) @map("start_date")
  endDate       DateTime?            @map("end_date")
}

model EmployeeOnProjects {
  project    Project @relation(fields: [projectId], references: [id])
  projectId  Int
  employee   User    @relation(fields: [employeeId], references: [id])
  employeeId Int

  @@id([projectId, employeeId])
}

model ProjectStage {
  id          Int          @id @default(autoincrement())
  project     Project      @relation(fields: [projectId], references: [id])
  projectId   Int
  title       String
  description String?
  stages      cout_stage[]
  tasks       Tasks[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  endDate     DateTime?    @map("end_date")
}

model Tasks {
  id             Int            @id @default(autoincrement())
  employee       User           @relation("AssignedTasks", fields: [employeeId], references: [id])
  project        Project        @relation("ProjectTasks", fields: [projectId], references: [id])
  projectId      Int
  employeeId     Int
  title          String
  description    String
  effort         Int?
  projectStage   ProjectStage   @relation(fields: [projectStageId], references: [id])
  projectStageId Int
  notification   Notification[] @relation("TaskNotifications")
  priority       TaskPriority   @default(BASSE)
  status         TaskStatus     @default(A_FAIRE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  endDate        DateTime?      @map("end_date")
}

enum TaskStatus {
  A_FAIRE
  EN_COURS
  TERMINE //par l'employee
  CANCELLED // par l'admin
}

enum TaskPriority {
  BASSE
  MOYENNE
  HAUTE
}

model Quote {
  id            Int            @id @default(autoincrement())
  number        String         @unique
  status        quoteStatus    @default(EN_ATTENTE)
  customer      User           @relation(fields: [customerId], references: [id])
  customerId    Int
  project       Project        @relation(fields: [projectId], references: [id])
  projectId     Int
  totalPrice    Float
  newTotalPrice Float?
  notification  Notification[] @relation("QuoteNotifications")
  stages        cout_stage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Invoice       Invoice[]
}

model cout_stage {
  quoteId        Int
  projectStageId Int
  quote          Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  projectStage   ProjectStage @relation(fields: [projectStageId], references: [id])
  prix           Float

  @@id([quoteId, projectStageId])
}

enum quoteStatus {
  ACCEPTE
  REFUSE
  EN_ATTENTE
}

model Invoice {
  id            Int            @id @default(autoincrement())
  invoiceNumber String         @unique
  quote         Quote          @relation(fields: [quoteId], references: [id])
  quoteId       Int
  totalAmount   Float
  amountPaid    Float
  balanceDue    Float
  notification  Notification[] @relation("InvoiceNotifications")
  invoiceDate   DateTime       @default(now())
  createdAt     DateTime       @default(now())
  User          User?          @relation(fields: [userId], references: [id])
  userId        Int
  paymentMethod paymentMethod  @default(Cash)
}

enum paymentMethod {
  OrangeMoney
  MTNMoney
  BankTransfer
  Cash
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  type      String // 'devis_valide', 'projet_cree', 'facture_envoyee', etc.
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // L'utilisateur concerné (client, admin ou employé)
  user   User? @relation("UserNotifications", fields: [userId], references: [id])
  userId Int

  // Lien optionnel vers un devis, projet ou facture
  quote     Quote?   @relation("QuoteNotifications", fields: [quoteId], references: [id])
  quoteId   Int?
  project   Project? @relation("ProjectNotifications", fields: [projectId], references: [id])
  projectId Int?
  invoice   Invoice? @relation("InvoiceNotifications", fields: [invoiceId], references: [id])
  invoiceId Int?
  task      Tasks?   @relation("TaskNotifications", fields: [taskId], references: [id]) // Nouvelle relation pour les tâches
  taskId    Int?

  @@index([userId])
}
